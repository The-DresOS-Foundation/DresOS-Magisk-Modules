<?xml version="1.0" encoding="utf-8"?>
<webviewproviders>

    <webviewprovider
        packageName="org.dresos.webview"
        description="DresOS WebView"
        availableByDefault="true">
        <signature></signature>
    </webviewprovider>

    <webviewprovider
        packageName="org.axpos.aosmium_wv"
        description="DresOS WebView 32-bit engine"
        availableByDefault="true">
        <signature></signature>
    </webviewprovider>

    <webviewprovider
        packageName="com.google.android.webview"
        description="Google WebView fallback"
        availableByDefault="true"
        isFallback="true">
    </webviewprovider>

    <webviewprovider
        packageName="com.android.webview"
        description="AOSP WebView fallback"
        availableByDefault="true">
    </webviewprovider>

</webviewproviders>
